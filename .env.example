# === Jira Credentials ===
# Personal Access Token for issues.redhat.com
# Primary env var for this tool. Falls back to JIRA_TOKEN if not set.
RELEASE_PLANNER_JIRA_TOKEN=your-jira-pat-here

# Email for Jira Cloud basic auth (set if using redhat.atlassian.net)
# JIRA_EMAIL=you@redhat.com

# Jira Server URL (default: https://issues.redhat.com)
# JIRA_SERVER=https://issues.redhat.com

# === Google Sheets (CLI only, not needed for web server) ===
# Option A: Path to JSON key file (recommended for local use)
# GOOGLE_CREDENTIALS_FILE=/path/to/service-account.json
# Option B: Inline JSON string (recommended for CI/containers)
# GOOGLE_CREDENTIALS_JSON={"type": "service_account", ...}

# Default Google Sheets spreadsheet ID (optional)
# DEFAULT_SPREADSHEET_ID=your-spreadsheet-id-here

# === Web Server ===
# Host to bind to (default: 127.0.0.1, use 0.0.0.0 for containers)
# RELEASE_PLANNER_HOST=127.0.0.1

# Port to listen on (default: 9000 -- avoids conflict with release-pulse on 8000)
# RELEASE_PLANNER_PORT=9000

# Path to frontend/ directory (auto-detected in dev, required for wheel installs)
# RELEASE_PLANNER_FRONTEND_DIR=/opt/app-root/frontend

# API key for simple auth (if unset, auth is disabled -- local dev mode)
# RELEASE_PLANNER_API_KEY=your-shared-api-key

# Log format: "text" (default) or "json" (for container log aggregation)
# RELEASE_PLANNER_LOG_FORMAT=text

# === General ===
# Rate limiting: seconds between Jira API queries (default: 1.0)
# JIRA_QUERY_DELAY=1.0

# Logging level (default: INFO)
# LOG_LEVEL=INFO

# Config and data directories (defaults: ./config, ./data)
# CONFIG_DIR=./config
# DATA_DIR=./data
